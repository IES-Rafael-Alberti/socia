---
// This component handles automatic language detection and redirection
---

<script is:inline>
  // The site lives at the apex of socia.fpciberseguridad.com — no base path.
  const currentPath = window.location.pathname;

  // Only run on the Spanish home.
  if (currentPath === '/' || currentPath === '') {
    const storedLang = localStorage.getItem('preferred-language');

    if (storedLang === 'en') {
      window.location.href = '/en/';
    } else if (!storedLang) {
      const browserLang = navigator.language || (navigator.languages && navigator.languages[0]) || '';
      if (browserLang.startsWith('en')) {
        localStorage.setItem('preferred-language', 'en');
        window.location.href = '/en/';
      } else {
        localStorage.setItem('preferred-language', 'es');
      }
    }
  }

  // Remember manual language navigation so future visits land on the right one.
  if (currentPath.startsWith('/en/')) {
    localStorage.setItem('preferred-language', 'en');
  } else if (currentPath === '/' || currentPath === '') {
    localStorage.setItem('preferred-language', 'es');
  }
</script>
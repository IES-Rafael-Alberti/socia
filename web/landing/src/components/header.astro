---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import LanguagePicker from "~/components/language-picker.astro";
import socialLogo from "~/assets/socia-logo.svg";
import type { NavItem } from "~/types";
import { useTranslations, languages } from "~/i18n";

export interface Props {
  lang: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const navItems: Array<NavItem> = [
  { title: t('nav.what'), url: "#what" },
  { title: t('nav.stack'), url: "#stack" },
  { title: t('nav.classroom'), url: "#flow" },
  { title: t('nav.partners'), url: "#partners" },
];

const docsHref = 'https://socia.fpciberseguridad.com/docs/';
---

<header
  id="page-header"
  class="sticky top-0 z-30 w-full border-b border-default/40 bg-white/85 backdrop-blur supports-[backdrop-filter]:bg-white/70"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a class="flex items-center gap-3 text-ink-800" href="#">
      <Image src={socialLogo} alt="SOCIA" class="h-9 w-9" widths={[72, 144]} sizes="36px" />
      <span class="font-display text-base font-extrabold uppercase tracking-[0.06em] text-ink-800">SOCIA</span>
    </a>

    <div class="flex items-center gap-6">
      <nav class="hidden md:block">
        <ul class="flex items-center gap-7">
          {
            navItems.map(({ title, url }) => (
              <li>
                <a class="text-sm font-semibold text-ink-700 hover:text-primary" href={url}>
                  {title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <a class="hidden md:inline-flex btn-primary" href={docsHref}>
        {t('nav.docs')}
      </a>
      {/* GitHub icon — visible only on mobile/tablet, since on lg+ the
          GitHub Corner already lives on the red hero panel. */}
      <a
        href="https://github.com/IES-Rafael-Alberti/socia"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex size-9 items-center justify-center rounded-full text-ink-700 hover:text-primary lg:hidden"
        aria-label="Ver SOCIA en GitHub"
      >
        <Icon name="fa-brands:github-alt" class="size-6" />
      </a>
      <LanguagePicker currentLang={lang} />
      <button
        id="open-nav-button"
        type="button"
        class="md:hidden"
        aria-label="Navigation"
      >
        <Icon name="mdi:menu" class="size-7 text-ink-800" />
      </button>
    </div>

    <div id="menu-modal" class="modal hidden" aria-hidden="true">
      <div class="fixed inset-0 z-40 bg-white px-6 py-4 text-ink-800">
        <div class="space-y-4" role="dialog" aria-modal="true">
          <header class="flex items-center justify-between">
            <span class="font-display text-xs font-bold uppercase tracking-[0.18em] text-primary">SOCIA</span>
            <button id="close-nav-button" type="button" aria-label="Close navigation">
              <Icon name="mdi:close" class="size-7" />
            </button>
          </header>
          <nav>
            <ul class="flex flex-col">
              {
                navItems.map(({ title, url }) => (
                  <li>
                    <a class="block border-b border-ink-100 py-4 text-lg font-semibold uppercase tracking-wide" href={url}>
                      {title}
                    </a>
                  </li>
                ))
              }
              <li class="pt-4">
                <a class="btn-primary w-full justify-center" href={docsHref}>
                  {t('nav.docs')}
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import MicroModal from "micromodal";
  import invariant from "tiny-invariant";

  const menuModalId = "menu-modal";
  const menu = document.querySelector(`#${menuModalId} ul`);
  const openNavButton = document.querySelector("#open-nav-button");
  const closeNavButton = document.querySelector("#close-nav-button");

  invariant(menu, "menu should not be null");
  invariant(openNavButton, "openNavButton should not be null");
  invariant(closeNavButton, "closeNavButton should not be null");

  openNavButton.addEventListener("click", () => MicroModal.show(menuModalId, { disableScroll: true }));
  closeNavButton.addEventListener("click", () => MicroModal.close(menuModalId));

  menu.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).tagName === "A") {
      MicroModal.close(menuModalId);
    }
  });
</script>

<style>
  .modal.is-open { display: block; }
</style>

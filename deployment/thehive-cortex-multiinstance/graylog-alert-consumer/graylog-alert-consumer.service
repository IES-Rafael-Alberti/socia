[Unit]
Description=SOCIA Graylog alert Kafka to TheHive consumer
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=socia-thehive
Group=socia-thehive
WorkingDirectory=/opt/socia-thehive/graylog-alert-consumer
EnvironmentFile=/opt/socia-thehive/graylog-alert-consumer/.env
ExecStart=/opt/socia-thehive/graylog-alert-consumer/venv/bin/python /opt/socia-thehive/graylog-alert-consumer/graylog-alert-consumer.py
Restart=always
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target

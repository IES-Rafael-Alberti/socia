# Puerto del servidor
PORT=4317

# Credenciales de acceso al panel
ADMIN_USER=admin
ADMIN_PASS=changeme

# Clave de sesión (cualquier string aleatorio largo)
SESSION_SECRET=please-change-this-secret-to-a-long-random-string

# OpenRouter — la key vive aquí, no en los alumnos
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL_HINTS=xiaomi/mimo-v2-flash
OPENROUTER_MODEL_EVAL=xiaomi/mimo-v2-flash

# Carpeta de datos persistentes (SQLite + workflows + PDFs)
DATA_DIR=./data

# Identidad visual del PDF de evaluación. IDs disponibles en
# packages/socia-branding/src/brands/. Si se deja vacío, se usa `socia`
# (genérico). Pon `ies-rafael-alberti`, `cifp-cuenca`, etc. para personalizar.
BRAND_ID=

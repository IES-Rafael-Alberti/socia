{
  "name": "socia-apps-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace pnpm de las apps SOCIA: extensiones MENTORA + SOCIA, servidor + panel docente, librerías internas y skills de agente.",
  "scripts": {
    "build": "pnpm -r --filter='./extensions' --filter='./server' --filter='./packages/*' build",
    "build:extensions": "pnpm --filter @socia/extensions build",
    "build:extensions:socia": "pnpm --filter @socia/extensions build:socia",
    "build:extensions:mentora": "pnpm --filter @socia/extensions build:mentora",
    "build:server": "pnpm --filter @socia/server build",
    "dev:extensions:socia": "pnpm --filter @socia/extensions dev:socia",
    "dev:extensions:mentora": "pnpm --filter @socia/extensions dev:mentora",
    "dev:server": "pnpm --filter @socia/server dev",
    "dev:server:panel": "pnpm --filter @socia/server dev:panel",
    "dev:server:all": "pnpm --filter @socia/server dev:all",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild",
      "sharp"
    ]
  }
}

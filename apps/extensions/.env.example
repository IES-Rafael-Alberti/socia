# Build-time environment variables for the SOCIA + MENTORA extensions.
#
# Copy this file to `.env` (it is gitignored) and fill in the keys you need.
# Variables MUST start with the `EXT_` prefix (configured in `wxt.config.ts`
# as `vite.envPrefix`). Anything without the prefix is ignored — Vite forces
# a prefix to keep server secrets out of the client bundle by accident.
#
# Changes require a rebuild (`pnpm dev:extensions:socia`, etc.). All
# variables are OPTIONAL — the extensions degrade gracefully when a key is
# missing.

# ─── MENTORA ────────────────────────────────────────────────────────────────

# OpenAI key for the Whisper transcription that runs at the end of each
# recording. Without it, MENTORA still produces the recording ZIP but the
# `transcription.srt` file is omitted.
#
#   Get one at:  https://platform.openai.com/api-keys
#   Cost:        $0.006 / minute of audio (whisper-1)
EXT_OPENAI_API_KEY=

# ─── SOCIA ──────────────────────────────────────────────────────────────────

# Default OpenRouter API key compiled into the extension. In practice this is
# rarely set: students enter their own key from Ajustes → "Modo standalone".
# Useful only if you want to ship a build with a pre-configured key.
#
#   Get one at:  https://openrouter.ai/keys
EXT_OPENROUTER_API_KEY=

# Models used by SOCIA in standalone mode. In managed mode the server picks
# the model. Defaults below match the production picks; override only when
# experimenting.
EXT_OPENROUTER_MODEL_HINTS=xiaomi/mimo-v2-flash
EXT_OPENROUTER_MODEL_EVAL=xiaomi/mimo-v2-flash

# Verbose logging in the hint overlay (useful when debugging the FAB).
EXT_DEBUG=false

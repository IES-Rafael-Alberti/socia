# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env al repositorio

# ── OPNsense ──────────────────────────────────────────────────────
OPNSENSE_URL=https://<IP_OPNSENSE>
OPNSENSE_USER=<usuario_opnsense>
OPNSENSE_PASS=<contraseña_opnsense>

# ── WireGuard (servidor) ───────────────────────────────────────────
# SERVER_UUID: UUID del servidor WireGuard en OPNsense
#   OPNsense → VPN → WireGuard → Servers → editar → copiar UUID de la URL
SERVER_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SERVER_PUBKEY: clave pública del servidor
#   OPNsense → VPN → WireGuard → Servers → columna "Public Key"
SERVER_PUBKEY=<clave_publica_servidor_base64=>

# WG_ENDPOINT: IP:puerto público del servidor WireGuard
WG_ENDPOINT=<ip_publica>:8822

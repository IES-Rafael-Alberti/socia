---
import Header from "~/components/header.astro";
import Hero from "~/components/hero.astro";
import What from "~/components/what.astro";
import Stack from "~/components/stack.astro";
import Flow from "~/components/flow.astro";
import Partners from "~/components/partners.astro";
import Funding from "~/components/funding.astro";
import Footer from "~/components/footer.astro";
import LanguageRedirect from "~/components/language-redirect.astro";
import "~/styles/index.css";
import { useTranslations } from "~/i18n";

const lang = 'es'
const t = useTranslations(lang)

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description = t('site.description')
---

<!doctype html>
<html lang="es" class="h-full motion-safe:scroll-smooth" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>{t('site.title')}</title>
    <meta name="description" content={description} />

    <!-- social media -->
    <meta property="og:title" content={t('site.title')} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="es" href="/socia/" />
    <link rel="alternate" hreflang="en" href="/socia/en/" />
    <link rel="alternate" hreflang="x-default" href="/socia/" />

    <!-- initialize theme -->
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        document.documentElement.dataset.theme = "light";
      }
    </script>
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default selection:bg-primary selection:text-white"
  >
    <LanguageRedirect />
    <Header lang={lang} />
    <main>
      <Hero lang={lang} />
      <What lang={lang} />
      <Stack lang={lang} />
      <Flow lang={lang} />
      <Partners lang={lang} />
      <Funding lang={lang} />
    </main>
    <Footer lang={lang} />
  </body>
</html>

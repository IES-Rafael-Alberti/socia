---
/*
  Mock of the SOCIA student extension popup mid-case.
  Tokens & DOM lifted 1:1 from referencias/entrypoints/socia/popup/style.css.
  All in-image labels are localised through the i18n table.
*/
import { useTranslations, languages } from "~/i18n";

export interface Props {
  lang?: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<div class="mock socia-mock">
  <header class="mock__header">
    <h1>SOCIA</h1>
    <span class="mock__gear" aria-hidden="true">⚙</span>
  </header>

  <div class="mock__body">
    {/* Live card: dark gradient + corner glow */}
    <div class="mock__live">
      <div class="mock__timer">12:42</div>
      <div class="mock__live-stats">
        <div class="mock__live-stat"><span class="mock__stat-value">87</span><span class="mock__stat-label">{t('mock.socia.actions')}</span></div>
        <div class="mock__live-stat"><span class="mock__stat-value">142</span><span class="mock__stat-label">{t('mock.socia.network')}</span></div>
        <div class="mock__live-stat"><span class="mock__stat-value">3/5</span><span class="mock__stat-label">{t('mock.socia.milestones')}</span></div>
      </div>
    </div>

    <div>
      <p class="mock__eyebrow">{t('mock.socia.case')}</p>
      <h2 class="mock__case-title">{t('mock.socia.title')}</h2>
    </div>

    {/* Segmented 5-step progress with shimmer on the current step */}
    <div class="mock__progress">
      <div class="mock__progress-track">
        <div class="mock__progress-step is-done"></div>
        <div class="mock__progress-step is-done"></div>
        <div class="mock__progress-step is-done"></div>
        <div class="mock__progress-step is-current"></div>
        <div class="mock__progress-step"></div>
      </div>
      <div class="mock__progress-label"><span>{t('mock.socia.milestones')}</span><strong>3/5</strong></div>
    </div>

    {/* Phase list — past, active, future */}
    <ul class="mock__phases">
      <li class="mock__phase is-past">
        <span class="mock__phase-icon"></span>
        <span class="mock__phase-name">{t('mock.socia.phase1')}</span>
      </li>
      <li class="mock__phase is-past">
        <span class="mock__phase-icon"></span>
        <span class="mock__phase-name">{t('mock.socia.phase2')}</span>
      </li>
      <li class="mock__phase is-active">
        <span class="mock__phase-icon"></span>
        <span class="mock__phase-name">{t('mock.socia.phase3')}</span>
      </li>
      <li class="mock__phase is-future">
        <span class="mock__phase-icon"></span>
        <span class="mock__phase-name">{t('mock.socia.phase4')}</span>
      </li>
      <li class="mock__phase is-future">
        <span class="mock__phase-icon"></span>
        <span class="mock__phase-name">{t('mock.socia.phase5')}</span>
      </li>
    </ul>
  </div>
</div>

<style>
  .socia-mock {
    --m-accent: #e93456;
    --m-accent-hover: #d42349;
    --m-accent-tint: #fff1f4;
    --m-success: #157a40;
    --m-ink-800: #14161b;
    --m-ink-700: #24272f;
    --m-ink-500: #525866;
    --m-ink-400: #7a8090;
    --m-ink-300: #a8aeb8;
    --m-ink-200: #cfd3da;
    --m-ink-100: #e6e8ec;
    --m-paper: #fafbfc;
    --m-white: #ffffff;
  }

  .mock {
    width: 100%;
    max-width: 380px;
    overflow: hidden;
    border-radius: 12px;
    background: var(--m-white);
    box-shadow: 0 24px 60px rgba(20, 22, 27, 0.18);
    font-family: 'Montserrat', system-ui, sans-serif;
    color: var(--m-ink-800);
    font-size: 13px;
    line-height: 1.5;
  }

  /* Header */
  .mock__header {
    background: var(--m-ink-800);
    color: var(--m-white);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--m-ink-700);
  }
  .mock__header h1 {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.06em;
    line-height: 1;
    margin: 0;
  }
  .mock__gear {
    width: 30px; height: 30px;
    border-radius: 6px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.75);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 15px;
  }

  .mock__body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Live card — dark with gradient + radial red glow */
  .mock__live {
    position: relative;
    background: linear-gradient(140deg, var(--m-ink-800) 0%, #1d1018 100%);
    color: var(--m-white);
    border-radius: 12px;
    padding: 18px 20px 16px;
    overflow: hidden;
  }
  .mock__live::after {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(233,52,86,0.35), transparent 70%);
    pointer-events: none;
  }

  .mock__timer {
    font-family: 'Montserrat', sans-serif;
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--m-white);
  }

  .mock__live-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.1);
    position: relative;
  }
  .mock__live-stat { text-align: left; display: block; }
  .mock__stat-value {
    display: block;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .mock__stat-label {
    display: block;
    margin-top: 6px;
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255,255,255,0.55);
  }

  /* Case title */
  .mock__eyebrow {
    margin: 0 0 4px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--m-accent);
  }
  .mock__case-title {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--m-ink-800);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }

  /* Progress */
  .mock__progress { display: flex; flex-direction: column; gap: 6px; }
  .mock__progress-track { display: flex; gap: 3px; }
  .mock__progress-step {
    flex: 1;
    height: 6px;
    border-radius: 999px;
    background: var(--m-ink-100);
    position: relative;
    overflow: hidden;
  }
  .mock__progress-step.is-done,
  .mock__progress-step.is-current { background: var(--m-accent); }
  .mock__progress-step.is-current::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
    animation: mock-shimmer 1.4s linear infinite;
  }
  @keyframes mock-shimmer {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }
  .mock__progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: 600;
    color: var(--m-ink-500);
  }
  .mock__progress-label strong { color: var(--m-ink-800); font-weight: 700; }

  /* Phases */
  .mock__phases {
    list-style: none;
    margin: 0; padding: 0;
    display: flex; flex-direction: column;
    gap: 6px;
  }
  .mock__phase {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 12px;
    font-size: 13px;
    background: var(--m-white);
    border: 1px solid var(--m-ink-100);
    border-radius: 10px;
  }
  .mock__phase-icon {
    flex-shrink: 0;
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1.5px solid var(--m-ink-300);
    background: var(--m-white);
    position: relative;
  }
  .mock__phase-name {
    flex: 1;
    font-weight: 600;
    color: var(--m-ink-800);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }

  /* Active phase: red border with red bullet */
  .mock__phase.is-active {
    border-color: var(--m-accent);
    box-shadow: 0 0 0 3px rgba(233, 52, 86, 0.08);
  }
  .mock__phase.is-active .mock__phase-icon {
    border-color: var(--m-accent);
    background: var(--m-accent);
  }
  .mock__phase.is-active .mock__phase-icon::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--m-white);
  }

  /* Past phase: paper bg, ink-400 strikethrough text, green check */
  .mock__phase.is-past { background: var(--m-paper); }
  .mock__phase.is-past .mock__phase-name {
    color: var(--m-ink-400);
    text-decoration: line-through;
    text-decoration-color: var(--m-ink-200);
  }
  .mock__phase.is-past .mock__phase-icon {
    border-color: var(--m-success);
    background: var(--m-success);
  }
  .mock__phase.is-past .mock__phase-icon::after {
    content: '';
    position: absolute;
    left: 4px; top: 7px;
    width: 7px; height: 3px;
    border-left: 2px solid var(--m-white);
    border-bottom: 2px solid var(--m-white);
    transform: rotate(-45deg);
  }

  .mock__phase.is-future { opacity: 0.7; }
</style>

---
import { Image } from "astro:assets";
import { useTranslations, languages } from "~/i18n";

export interface Props {
  site: {
    data: {
      title: string;
      url: string;
      image: any;
      imageWhite?: any;
    };
  };
  lang: keyof typeof languages;
}

const { site, lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const widths = [600, 1200];
const sizes = "(min-width: 768px) 33vw, 100vw";
---

<a class="group block hover:!text-default" href={site.data.url} target="_blank" rel="noopener noreferrer">
  <figure class="relative h-48 w-full overflow-hidden transition-all duration-300 group-hover:scale-105">
    {site.data.imageWhite ? (
      <>
        <Image
          class="h-full w-full object-contain p-6 transition-all duration-300 group-hover:opacity-80 block dark:hidden"
          src={site.data.image}
          widths={widths}
          sizes={sizes}
          alt={`Logo de ${site.data.title}`}
        />
        <Image
          class="h-full w-full object-contain p-6 transition-all duration-300 group-hover:opacity-80 hidden dark:block"
          src={site.data.imageWhite}
          widths={widths}
          sizes={sizes}
          alt={`Logo de ${site.data.title}`}
        />
      </>
    ) : (
      <Image
        class="h-full w-full object-contain p-6 transition-all duration-300 group-hover:opacity-80"
        src={site.data.image}
        widths={widths}
        sizes={sizes}
        alt={`Logo de ${site.data.title}`}
      />
    )}
    <figcaption class="absolute inset-0 bg-black/80 opacity-0 transition-all duration-300 group-hover:opacity-100 flex items-center justify-center">
      <div class="text-center text-white">
        <h3 class="font-bold text-lg mb-2">
          {site.data.title}
        </h3>
        <p class="border border-white/50 px-4 py-2 text-sm rounded inline-block">
          {t('collaborators.visit')}
        </p>
      </div>
    </figcaption>
  </figure>
</a>
---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import HeroImage from "~/components/hero-image.astro";
import ministerioLogo from "~/assets/ministerio.svg";
import type { FooterLink } from "~/types";
import { useTranslations, languages } from "~/i18n";

export interface Props {
  lang: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const links: Array<FooterLink> = [
  {
    url: "https://github.com/socia-platform",
    description: "SOCIA en GitHub",
    icon: "fa-brands:github-alt",
  },
  {
    url: "https://iesrafaelalberti.es/",
    description: "IES Rafael Alberti",
    icon: "mdi:school",
  },
  {
    url: "https://cifpcuenca.es/",
    description: "CIFP Nº1 - Cuenca",
    icon: "mdi:school",
  },
  {
    url: "https://aktios.com/",
    description: "Aktios Security Services",
    icon: "mdi:shield-account",
  },
];
---

<footer class="relative bg-gray-900 py-16">
  <div class="container mx-auto px-8 text-center">
  

      <div class="mb-4">
        <p class="text-gray-400 text-sm mb-4">
          {t('footer.funded')}
        </p>
        <div class="flex justify-center mb-4">
          <Image
            src={ministerioLogo}
            alt="Ministerio de Educación y Formación Profesional"
            class="h-16 w-auto"
            widths={[200, 400]}
            sizes="200px"
          />
        </div>
        <p class="text-gray-400 text-sm">
          {t('footer.project')}
        </p>
      </div>
      
      <div class="text-gray-500 text-sm">
        <p>&copy; 2025 {t('footer.rights')}</p>
        <p class="mt-1">
          {t('footer.initiative')}
        </p>
      </div>
    </div>
  </div>
</footer>

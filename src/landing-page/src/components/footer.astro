---
import { Image } from "astro:assets";
import socialLogo from "~/assets/socia-logo.svg";
import { useTranslations, languages } from "~/i18n";

export interface Props {
  lang: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<footer class="relative overflow-hidden bg-primary text-white">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-6 py-20 text-center">
    <div class="grid size-16 place-items-center rounded-full bg-white/15 p-2 ring-1 ring-white/20">
      <Image src={socialLogo} alt="" class="h-full w-full object-contain" widths={[120, 240]} sizes="48px" />
    </div>
    <div>
      <p class="script text-3xl text-white">{t('footer.tag')}</p>
      <p class="font-display mt-1 text-sm font-bold uppercase tracking-[0.14em] text-white">
        {t('footer.tag2')}
      </p>
    </div>
    <p class="max-w-xl text-sm leading-relaxed text-white/85">
      {t('footer.legal')}
    </p>
  </div>

  <div class="border-t border-white/20">
    <div class="mx-auto flex max-w-7xl items-center justify-center px-6 py-5 text-center text-xs text-white/80">
      <p>© {t('footer.year')} IES Rafael Alberti · CIFP N.º 1 Cuenca · Aktios Security Services</p>
    </div>
  </div>
</footer>

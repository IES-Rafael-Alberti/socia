---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { FeatureItem } from "~/types";
import { useTranslations, languages } from "~/i18n";

export interface Props {
  lang: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const features: Array<FeatureItem> = [
  {
    title: t('features.soc.title'),
    description: t('features.soc.description'),
    icon: "mdi:shield-check",
  },
  {
    title: t('features.ai.title'),
    description: t('features.ai.description'),
    icon: "mdi:robot",
  },
  {
    title: t('features.challenges.title'),
    description: t('features.challenges.description'),
    icon: "mdi:trophy",
  },
  {
    title: t('features.opensource.title'),
    description: t('features.opensource.description'),
    icon: "mdi:open-source-initiative",
  },
];
---

<ContentSection title={t('features.title')} id="features">
  <Fragment slot="lead" set:html={t('features.lead')} />
  <ul class="grid max-w-6xl grid-cols-1 md:grid-cols-2 lg:grid-cols-2">
    {
      features.map(({ title, description, icon }) => (
        <li class="flex flex-col items-center gap-4 border border-default bg-offset p-6">
          <div class="size-16 rounded-full border-2 border-current p-3">
            <Icon name={icon} class="size-full" />
          </div>
          <p class="text-center font-extrabold text-xl">{title}</p>
          <p class="text-center text-offset text-sm">{description}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>

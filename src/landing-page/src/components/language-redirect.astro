---
// This component handles automatic language detection and redirection
---

<script is:inline>
  // Only run on the default page (Spanish)
  if (window.location.pathname === '/') {
    // Check if user has a language preference stored
    const storedLang = localStorage.getItem('preferred-language');
    
    if (storedLang === 'en') {
      window.location.href = '/en/';
    } else if (!storedLang) {
      // Detect browser language
      const browserLang = navigator.language || navigator.languages[0];
      
      // If browser is set to English, redirect to English version
      if (browserLang.startsWith('en')) {
        localStorage.setItem('preferred-language', 'en');
        window.location.href = '/en/';
      } else {
        // Default to Spanish
        localStorage.setItem('preferred-language', 'es');
      }
    }
  }
  
  // Store language preference when user manually navigates
  if (window.location.pathname.startsWith('/en/')) {
    localStorage.setItem('preferred-language', 'en');
  } else {
    localStorage.setItem('preferred-language', 'es');
  }
</script>
---
import ContentSection from "~/components/content-section.astro";
import { Icon } from "astro-icon/components";
---

<ContentSection title="Objetivos del Proyecto" id="objectives">
  <Fragment slot="lead">
    SOCIA busca <span class="text-primary">revolucionar</span> la formación en ciberseguridad mediante 
    <span class="text-primary">tecnologías innovadoras</span> y <span class="text-primary">colaboración</span> 
    entre centros educativos y empresas del sector.
  </Fragment>
  
  <div class="grid gap-8 md:grid-cols-2">
    <div class="space-y-6">
      <h3 class="text-xl font-bold text-primary mb-4">Objetivos Generales</h3>
      
      <div class="flex gap-4 items-start">
        <div class="flex-shrink-0 w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center">
          <Icon name="mdi:shield-check" class="size-4 text-white" />
        </div>
        <div>
          <h4 class="font-semibold mb-2">SOC Simulado</h4>
          <p class="text-sm text-offset">Implementar un Centro de Operaciones de Seguridad simulado con IA para formación práctica</p>
        </div>
      </div>
      
      <div class="flex gap-4 items-start">
        <div class="flex-shrink-0 w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center">
          <Icon name="mdi:handshake" class="size-4 text-white" />
        </div>
        <div>
          <h4 class="font-semibold mb-2">Alianzas Estratégicas</h4>
          <p class="text-sm text-offset">Establecer colaboraciones con empresas para intercambio de buenas prácticas</p>
        </div>
      </div>
      
      <div class="flex gap-4 items-start">
        <div class="flex-shrink-0 w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
          <Icon name="mdi:trophy" class="size-4 text-white" />
        </div>
        <div>
          <h4 class="font-semibold mb-2">Aprendizaje Basado en Retos</h4>
          <p class="text-sm text-offset">Diseñar metodología innovadora con competencias transversales</p>
        </div>
      </div>
      
      <div class="flex gap-4 items-start">
        <div class="flex-shrink-0 w-8 h-8 bg-orange-600 rounded-full flex items-center justify-center">
          <Icon name="mdi:network" class="size-4 text-white" />
        </div>
        <div>
          <h4 class="font-semibold mb-2">Ecosistema Colaborativo</h4>
          <p class="text-sm text-offset">Fomentar colaboración sostenible entre centros y empresas</p>
        </div>
      </div>
    </div>
    
    <div class="space-y-6">
      <h3 class="text-xl font-bold text-primary mb-4">Beneficiarios</h3>
      
      <div class="space-y-4">
        <div class="bg-gray-800 p-4 rounded-lg">
          <h4 class="font-semibold mb-2 text-blue-400">Alumnado</h4>
          <p class="text-sm text-gray-300">Habilidades prácticas, aprendizaje personalizado con IA, experiencia con tecnologías de vanguardia</p>
        </div>
        
        <div class="bg-gray-800 p-4 rounded-lg">
          <h4 class="font-semibold mb-2 text-purple-400">Profesorado</h4>
          <p class="text-sm text-gray-300">Herramientas innovadoras, formación continua, colaboración con expertos del sector</p>
        </div>
        
        <div class="bg-gray-800 p-4 rounded-lg">
          <h4 class="font-semibold mb-2 text-green-400">Centros Educativos</h4>
          <p class="text-sm text-gray-300">Posicionamiento como referentes, metodologías replicables, espacios formativos adaptados</p>
        </div>
        
        <div class="bg-gray-800 p-4 rounded-lg">
          <h4 class="font-semibold mb-2 text-orange-400">Empresas</h4>
          <p class="text-sm text-gray-300">Formación de futuros profesionales, intercambio de conocimientos, colaboración estratégica</p>
        </div>
      </div>
    </div>
  </div>
</ContentSection>

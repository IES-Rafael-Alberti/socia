---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import socialLogo from "~/assets/socia-logo.svg";
import mentoraLogo from "~/assets/mentora-logo.svg";
import MentoraPopup from "~/components/mocks/mentora-popup.astro";
import SociaPopup from "~/components/mocks/socia-popup.astro";
import HintBulb from "~/components/mocks/hint-bulb.astro";
import ServerPanel from "~/components/mocks/server-panel.astro";
import Reveal from "~/components/reveal.astro";
import { useTranslations, languages, translations, defaultLang } from "~/i18n";

export interface Props {
  lang: keyof typeof languages;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const lookup = translations[lang] ?? translations[defaultLang];

/*
  Featured stack tools. We show only the four most representative pieces
  (the typical first-day SOC console + traffic + DFIR + perimeter), plus a
  fifth "Y más" tile that nods to T-Pot, vulnerable VMs and friends — kept
  brief on purpose. The rest is documented in the install guide.
*/
import wazuhLogo from "~/assets/tools/wazuh.png";
import malcolmLogo from "~/assets/tools/malcolm.png";
import velociraptorLogo from "~/assets/tools/velociraptor.svg";
import opnsenseLogo from "~/assets/tools/opnsense.png";

const tools = [
  { key: 'wazuh',        logo: wazuhLogo },
  { key: 'malcolm',      logo: malcolmLogo },
  { key: 'velociraptor', logo: velociraptorLogo },
  { key: 'opnsense',     logo: opnsenseLogo },
  { key: 'more',         logo: null },
];

const pieces = [
  {
    key: 'mentora',
    logo: mentoraLogo,
    skills: lookup['pieces.mentora.skills'] as readonly string[],
  },
  {
    key: 'socia',
    logo: socialLogo,
    skills: lookup['pieces.socia.skills'] as readonly string[],
  },
];
---

<section id="stack" class="bg-alberti-paper py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <Reveal class="max-w-3xl">
      <p class="eyebrow">— {t('stack.eyebrow')}</p>
      <h2 class="headline mt-3 text-4xl text-ink-800 sm:text-5xl">
        {t('stack.title')}
      </h2>
    </Reveal>

    {/* Sub-block 1 — the SOC infrastructure */}
    <div class="mt-20">
      <Reveal class="flex items-baseline justify-between gap-6 border-b border-ink-200 pb-4">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-primary">01 · {t('stack.soc.subtitle')}</p>
          <h3 class="mt-1 font-display text-2xl font-extrabold uppercase tracking-tight text-ink-800">
            {t('stack.soc.heading')}
          </h3>
        </div>
        <p class="hidden max-w-md text-sm text-ink-500 sm:block">{t('stack.soc.desc')}</p>
      </Reveal>

      {/*
        SOC tiles — each tile shows a wordmark. On hover, the wordmark fades
        out and a brief role + description fades in. Same interaction as the
        Partners cards, but with a cleaner inline SVG glyph for each tool.
      */}
      {/*
        Mobile: 2 columns, height 36 (no aspect-ratio so tiles aren't huge).
        Tablet+: keep 2 cols. lg+: 5 cols with the original 4/3 aspect.
        Logos and wordmark scale up on mobile so they actually read.
      */}
      <ul class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-5">
        {
          tools.map(({ key, logo }, i) => (
            <Reveal as="li" delay={i * 70} class="group relative h-40 overflow-hidden rounded-2xl border border-ink-100 bg-white transition-colors hover:bg-alberti-paper sm:h-44 lg:aspect-[4/3] lg:h-auto">
              <div class="flex h-full flex-col items-center justify-center gap-3 p-5 transition-opacity duration-300 group-hover:opacity-0">
                {logo ? (
                  <Image
                    src={logo}
                    alt={t(`stack.${key}.title` as any) as string}
                    class="h-12 w-auto max-w-[80%] object-contain sm:h-14"
                    widths={[120, 240]}
                    sizes="120px"
                  />
                ) : (
                  <div class="flex gap-1.5 text-ink-400">
                    <span class="size-2 rounded-full bg-current"></span>
                    <span class="size-2 rounded-full bg-current"></span>
                    <span class="size-2 rounded-full bg-current"></span>
                  </div>
                )}
                <span class="font-display text-sm font-bold uppercase tracking-[0.16em] text-ink-700 lg:text-xs">
                  {t(`stack.${key}.title` as any)}
                </span>
              </div>

              {/* Hover overlay */}
              <div class="absolute inset-0 flex flex-col justify-between p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <p class="text-[10px] font-bold uppercase tracking-[0.16em] text-primary">
                  {t(`stack.${key}.role` as any)}
                </p>
                <div>
                  <h4 class="font-display text-base font-extrabold uppercase leading-tight tracking-tight text-ink-800">
                    {t(`stack.${key}.title` as any)}
                  </h4>
                  <p class="mt-1.5 text-[12.5px] leading-snug text-ink-600">
                    {t(`stack.${key}.desc` as any)}
                  </p>
                </div>
              </div>
            </Reveal>
          ))
        }
      </ul>
    </div>

    {/*
      Sub-block 2 — the AI layer.
      Editorial layout, Apple-style: each piece gets its own row with the
      mock on one side and the copy on the other, alternating sides.
      No more compressed cards; the popups are the protagonists.
    */}
    <div class="mt-24">
      <Reveal class="flex items-baseline justify-between gap-6 border-b border-ink-200 pb-4">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-primary">02 · {t('stack.ai.subtitle')}</p>
          <h3 class="mt-1 font-display text-2xl font-extrabold uppercase tracking-tight text-ink-800">
            {t('stack.ai.heading')}
          </h3>
        </div>
        <p class="hidden max-w-md text-sm text-ink-500 sm:block">{t('stack.ai.desc')}</p>
      </Reveal>

      {/* Row 1 — MENTORA: copy on the left, popup on the right */}
      <div class="mt-16 grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
        <Reveal class="lg:col-span-5">
          <div class="flex items-center gap-3">
            <div class="grid size-10 shrink-0 place-items-center rounded-full bg-alberti-paper p-1.5 ring-1 ring-ink-100">
              <Image src={mentoraLogo} alt="Logo MENTORA" class="h-full w-full object-contain" />
            </div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-primary">{t('pieces.mentora.tag')}</p>
          </div>
          <h4 class="mt-4 font-display text-4xl font-extrabold uppercase tracking-tight text-ink-800">
            {t('pieces.mentora.title')}
          </h4>
          <p class="mt-5 text-lg leading-relaxed text-ink-500">
            {t('pieces.mentora.desc')}
          </p>
        </Reveal>
        <Reveal class="flex justify-center lg:col-span-7 lg:justify-start" delay={140}>
          <MentoraPopup lang={lang} />
        </Reveal>
      </div>

      {/* Row 2 — SOCIA: popup on the left, copy on the right (mirror) */}
      <div class="mt-24 grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
        <Reveal class="relative flex justify-center lg:col-span-7 lg:justify-end lg:order-1">
          <div class="relative">
            <SociaPopup lang={lang} />
            {/* Floating hint bulb — same control the alumnado sees.
                Visible in every viewport since it's the headline interaction. */}
            <div class="pointer-events-none absolute -bottom-4 -right-4">
              <HintBulb lang={lang} />
            </div>
          </div>
        </Reveal>
        <Reveal class="lg:col-span-5 lg:order-2" delay={140}>
          <div class="flex items-center gap-3">
            <div class="grid size-10 shrink-0 place-items-center rounded-full bg-alberti-paper p-1.5 ring-1 ring-ink-100">
              <Image src={socialLogo} alt="Logo SOCIA" class="h-full w-full object-contain" />
            </div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-primary">{t('pieces.socia.tag')}</p>
          </div>
          <h4 class="mt-4 font-display text-4xl font-extrabold uppercase tracking-tight text-ink-800">
            {t('pieces.socia.title')}
          </h4>
          <p class="mt-5 text-lg leading-relaxed text-ink-500">
            {t('pieces.socia.desc')}
          </p>
        </Reveal>
      </div>

      {/* Row 3 — Server panel, full width below */}
      <div class="mt-24">
        <Reveal class="flex flex-wrap items-baseline justify-between gap-4 border-b border-ink-200 pb-4">
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-primary">— {t('stack.server.eyebrow')}</p>
            <h4 class="mt-1 font-display text-2xl font-extrabold uppercase tracking-tight text-ink-800">
              {t('stack.server.title')}
            </h4>
          </div>
          <p class="max-w-md text-sm text-ink-500">
            {t('stack.server.body')}
          </p>
        </Reveal>

        <Reveal class="mt-8 overflow-hidden rounded-2xl ring-1 ring-ink-100" delay={120}>
          <div class="server-panel-frame">
            <ServerPanel lang={lang} />
          </div>
        </Reveal>
      </div>
    </div>
  </div>
</section>

<style>
  /* The server panel mock has a fixed reference size of 920×580.
     We scale it via JS below so it fits any container width without
     breaking its internal grid. */
  .server-panel-frame {
    width: 100%;
    aspect-ratio: 1100 / 700;
    overflow: hidden;
    position: relative;
  }
  .server-panel-frame :global(.server-mock) {
    transform-origin: top left;
  }
</style>

<script is:inline>
  (function () {
    const REF_WIDTH = 1100;
    function fit() {
      document.querySelectorAll('.server-panel-frame').forEach((frame) => {
        const mock = frame.querySelector('.server-mock');
        if (!mock) return;
        const w = frame.clientWidth;
        const scale = w / REF_WIDTH;
        mock.style.transform = 'scale(' + scale + ')';
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fit);
    } else {
      fit();
    }
    window.addEventListener('resize', fit);
    // Run once more after fonts may have loaded so layout is final.
    setTimeout(fit, 200);
  })();
</script>

